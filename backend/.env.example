# Copy to .env and adjust as needed.
# Defaults to a local SQLite file so the app runs without PostgreSQL.
# For Postgres use e.g.:
# DATABASE_URL=postgresql+psycopg2://cpft:cpft@localhost:5432/cpft
DATABASE_URL=sqlite:///./cpft_dev.db

# Secret used to sign auth tokens (change in production)
SECRET_KEY=change-me-in-production
